# GyanDev — environment variables
#
# Copy to `.env` for local development. All `PUBLIC_*` vars are inlined into the
# client bundle at build time, so never put secrets here. Values consumed by the
# Cloudflare Pages production build live in the CF dashboard, not in this file.

# Canonical site URL — BaseLayout and feed builders currently read this from
# `src/lib/routes.ts#SITE`; this var is present for parity with non-Pages
# deploy targets and scripts that don't import from the source tree.
PUBLIC_SITE_URL=https://gyandev.org

# Search Console / Bing Webmaster verification meta-tag values.
# Plain tokens (no `<meta>` markup); BaseLayout wraps them.
PUBLIC_GOOGLE_VERIFY=
PUBLIC_BING_VERIFY=

# Giscus comments — created at https://giscus.app for the target GitHub repo.
# `PUBLIC_GISCUS_REPO` is `owner/name`. The two ID fields come from the giscus
# config generator and are required for `mapping="specific"`.
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY_ID=

# Optional IndexNow / Search Console ping token for `scripts/submit-sitemap.mjs`.
# Leave blank to skip submission (script becomes a no-op). Only set in the
# production CF environment, never committed.
SITEMAP_SUBMIT_TOKEN=
