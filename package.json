    "validate": "astro check",
    "validate:slugs": "node scripts/validate-slugs.mjs",
    "check:content": "node scripts/validate-content.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:csp": "node scripts/check-csp.mjs",
    "check:schema": "node scripts/validate-schema.mjs",
    "check:legal": "node scripts/check-legal-freshness.mjs",
    "check:lhci": "lhci autorun --config=.lighthouserc.cjs",
    "check": "npm run validate && npm run validate:slugs && npm run check:contrast && npm run check:csp && npm run check:content && npm run check:legal && npm run build && npm run check:bundle && npm run check:schema",
    "smoke": "node scripts/smoke-deploy.mjs",
    "smoke:local": "BASE_URL=http://localhost:4321 node scripts/smoke-deploy.mjs",
    "verify:giscus": "node scripts/verify-giscus.mjs",
