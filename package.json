{
  "name": "gyandev-temp",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/check-bundle-size.mjs",
    "preview": "astro preview",
