---
/**
 * Chapter — Quick Revision (noindex, canonical → Full Notes).
 *
 * Renders the sibling `revision.mdx` body via the `chapterViews`
 * collection. When the entry is missing the route still ships (so deep
 * links don't 404), but the body is `<ComingSoonView>` and the tab in
 * the persisted shell is rendered as `aria-disabled` (handled by
 * `ChapterShell` via the `availability` prop).
 */
import { render } from 'astro:content';

import ChapterLayout from '../../../../layouts/ChapterLayout.astro';
import ChapterContent from '../../../../components/pages/chapter/ChapterContent.astro';
import ComingSoonView from '../../../../components/pages/chapter/ComingSoonView.astro';
import { getChapterPaths } from '../../../../lib/paths';
import { getChapterContext } from '../../../../lib/chapter/getChapterContext';
import { prevNext } from '../../../../lib/chapter/prevNext';
import { canonicalFor, chapterUrl } from '../../../../lib/routes';

export { getChapterPaths as getStaticPaths };

const { chapter } = Astro.props;
const ctx = await getChapterContext(chapter);
const { course, courseSlug, chapterSlug, revision, availability, bundle } = ctx;

const { prev, next } = await prevNext(courseSlug, chapterSlug);

const fullNotesUrl = canonicalFor(chapterUrl(courseSlug, chapterSlug));
const ogImage = canonicalFor(`/og/courses/${courseSlug}/${chapterSlug}.png`);
const editUrl = revision
  ? `https://github.com/sonushahuji4/gyandev/edit/main/src/content/courses/${courseSlug}/${chapterSlug}/revision.mdx`
  : `https://github.com/sonushahuji4/gyandev/new/main/src/content/courses/${courseSlug}/${chapterSlug}/?filename=revision.mdx`;
const reportIssueUrl = `https://github.com/sonushahuji4/gyandev/issues/new?title=${encodeURIComponent(`[revision] ${course.data.title} / ${chapter.data.title}`)}`;

let Content: any = null;
let headings: import('astro').MarkdownHeading[] = [];
let displayedReadingMinutes = chapter.data.readingMinutes;
let displayedUpdated = chapter.data.updated;

if (revision) {
  const rendered = await render(revision);
  Content = rendered.Content;
  headings = rendered.headings;
  if (revision.data.readingMinutes) displayedReadingMinutes = revision.data.readingMinutes;
  if (revision.data.updated) displayedUpdated = revision.data.updated;
}
---

<ChapterLayout
  chapter={chapter}
  course={course}
  courseSlug={courseSlug}
  chapterSlug={chapterSlug}
  tab="revision"
  availability={availability}
  chapters={bundle.chapters}
  headings={headings}
  prev={prev}
  next={next}
  editUrl={editUrl}
  reportIssueUrl={reportIssueUrl}
  ogImage={ogImage}
  displayedReadingMinutes={displayedReadingMinutes}
  displayedUpdated={displayedUpdated}
>
  {Content ? (
    <ChapterContent Content={Content} tab="revision" courseTitle={course.data.title} />
  ) : (
    <ComingSoonView missingTab="revision" fullNotesUrl={fullNotesUrl} />
  )}
</ChapterLayout>
