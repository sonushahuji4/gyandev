---
/**
 * Chapter — Flow Diagram (noindex, canonical → Full Notes).
 *
 * Mermaid runtime is auto-injected by `astro-mermaid` (PR-3 setup) on any
 * page that contains a ` ```mermaid ` fence. Per chapter.md §3.6 these
 * fences are only allowed in `flow.mdx`, so the runtime cost stays
 * isolated to this route — `validate-content.mjs` (PR-5.2) enforces.
 *
 * PR-5.0 spike confirmed astro-mermaid handles `astro:page-load` swap
 * correctly via its `astro:after-swap` listener; no extra wiring needed.
 */
import { render } from 'astro:content';

import ChapterLayout from '../../../../layouts/ChapterLayout.astro';
import ChapterContent from '../../../../components/pages/chapter/ChapterContent.astro';
import ComingSoonView from '../../../../components/pages/chapter/ComingSoonView.astro';
import { getChapterPaths } from '../../../../lib/paths';
import { getChapterContext } from '../../../../lib/chapter/getChapterContext';
import { prevNext } from '../../../../lib/chapter/prevNext';
import { canonicalFor, chapterUrl } from '../../../../lib/routes';

export { getChapterPaths as getStaticPaths };

const { chapter } = Astro.props;
const ctx = await getChapterContext(chapter);
const { course, courseSlug, chapterSlug, flow, availability, bundle } = ctx;

const { prev, next } = await prevNext(courseSlug, chapterSlug);

const fullNotesUrl = canonicalFor(chapterUrl(courseSlug, chapterSlug));
const ogImage = canonicalFor(`/og/courses/${courseSlug}/${chapterSlug}.png`);
const editUrl = flow
  ? `https://github.com/sonushahuji4/gyandev/edit/main/src/content/courses/${courseSlug}/${chapterSlug}/flow.mdx`
  : `https://github.com/sonushahuji4/gyandev/new/main/src/content/courses/${courseSlug}/${chapterSlug}/?filename=flow.mdx`;
const reportIssueUrl = `https://github.com/sonushahuji4/gyandev/issues/new?title=${encodeURIComponent(`[flow] ${course.data.title} / ${chapter.data.title}`)}`;

let Content: any = null;
let headings: import('astro').MarkdownHeading[] = [];
let displayedReadingMinutes = chapter.data.readingMinutes;
let displayedUpdated = chapter.data.updated;

if (flow) {
  const rendered = await render(flow);
  Content = rendered.Content;
  headings = rendered.headings;
  if (flow.data.readingMinutes) displayedReadingMinutes = flow.data.readingMinutes;
  if (flow.data.updated) displayedUpdated = flow.data.updated;
}
---

<ChapterLayout
  chapter={chapter}
  course={course}
  courseSlug={courseSlug}
  chapterSlug={chapterSlug}
  tab="flow"
  availability={availability}
  chapters={bundle.chapters}
  headings={headings}
  prev={prev}
  next={next}
  editUrl={editUrl}
  reportIssueUrl={reportIssueUrl}
  ogImage={ogImage}
  displayedReadingMinutes={displayedReadingMinutes}
  displayedUpdated={displayedUpdated}
>
  {Content ? (
    <ChapterContent Content={Content} tab="flow" courseTitle={course.data.title} />
  ) : (
    <ComingSoonView missingTab="flow" fullNotesUrl={fullNotesUrl} />
  )}
</ChapterLayout>
