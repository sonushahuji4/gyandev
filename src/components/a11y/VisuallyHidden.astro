---
/**
 * Content that is visually hidden but exposed to assistive technology.
 *
 *   <VisuallyHidden>More context for screen readers</VisuallyHidden>
 *
 * Renders a tag with `.sr-only` (defined in global.css @layer utilities). Use
 * `as="span"` (default) inside inline flow; use `as="div"` when wrapping block
 * content.
 */

interface Props {
  as?: 'span' | 'div';
  class?: string;
}

const { as: Tag = 'span', class: className } = Astro.props;
---

<Tag class:list={['sr-only', className]}>
  <slot />
</Tag>
