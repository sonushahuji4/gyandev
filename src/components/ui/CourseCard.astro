---
/**
 * CourseCard — single catalog tile (DevNotes-style revamp, Sprint 7).
 *
 * Layout, left to right, top to bottom:
 *   ┌ letter badge ─────────────── chapter count ─┐
 *   │  JS                          42  CHAPTERS   │
 *   │                                             │
 *   │  Course title                               │
 *   │  Two- or three-line description...          │
 *   │                                             │
 *   │  12h full · 62m revision                    │
 *   └─────────────────────────────────────────────┘
 *
 * `course.data.icon` is interpreted as short letter badge text — `"N"`,
 * `"JS"`, `"TS"`, `"DSA"`, `"NX"`. Legacy asset paths (leading slash) fall
 * back to an `<img>` so any stale content keeps rendering.
 *
 * Render modes:
 *   - `status === 'published'`  → full-area `<a>`.
 *   - otherwise (coming-soon / draft) → `<div aria-disabled="true">`; the card
 *     is visible but not focusable, meta row is replaced by a "Coming soon"
 *     badge, and the whole card dims.
 *
 * Progress slot is rendered hidden and flipped visible by
 * `src/scripts/progress-hydrate.ts`. The `data-course-slug` /
 * `data-chapter-count` / `data-course-status` attributes are the hydration
 * contract — keep in sync with that script and `home-hydrate.ts`'s
 * chapter-count lookup on the continue card.
 */
import type { CollectionEntry } from 'astro:content';
import { courseUrl } from '../../lib/routes';
import type { CourseStats } from '../../lib/courses/aggregate';

export interface Props {
  course: CollectionEntry<'courses'>;
  slug: string;
  stats: CourseStats;
  /** First row of the grid — opt out of lazy image loading for legacy icons. */
  priority?: boolean;
}

const { course, slug, stats, priority = false } = Astro.props;
const { title, description, difficulty, icon, status, estimatedHours } = course.data;

const isPublished = status === 'published';
const isComingSoon = status === 'coming-soon';
const href = isPublished ? courseUrl(slug) : undefined;

const isLegacyImageIcon = typeof icon === 'string' && icon.startsWith('/');
const badgeText = !isLegacyImageIcon ? (icon ?? title.slice(0, 2).toUpperCase()) : '';

const chapterCount = isPublished ? stats.publishedChapters : 0;
const hoursFromChapters = Math.round(stats.totalReadingMinutes / 60);
const hoursLabel = isPublished
  ? hoursFromChapters > 0
    ? `${hoursFromChapters}h full`
    : null
  : estimatedHours
    ? `~${estimatedHours}h full`
    : null;

const revisionMinutes = stats.revisionReadingMinutes;
const revisionLabel =
  isPublished && revisionMinutes > 0 ? `${revisionMinutes}m revision` : null;

const filterTags = [difficulty].filter(Boolean).join(',');
const Wrapper = isPublished ? 'a' : 'div';
---

<li class="course-card-cell">
  <Wrapper
    class:list={[
      'course-card',
      !isPublished && 'course-card--inactive',
      isComingSoon && 'course-card--coming-soon',
    ]}
    {...isPublished
      ? { href }
      : { role: 'group', 'aria-disabled': 'true' }}
    data-course-slug={slug}
    data-chapter-count={stats.publishedChapters}
    data-course-status={status}
    data-tags={filterTags}
  >
    <div class="course-card__head">
      {isLegacyImageIcon ? (
        <img
          class="course-card__badge-img"
          src={icon}
          alt=""
          width="48"
          height="48"
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          aria-hidden="true"
        />
      ) : (
        <span class="course-card__badge" aria-hidden="true">{badgeText}</span>
      )}
      {isComingSoon ? (
        <span class="course-card__pill">Coming soon</span>
      ) : (
        <span class="course-card__count">
          <span class="course-card__count-n">{chapterCount}</span>
          <span class="course-card__count-label">Chapters</span>
        </span>
      )}
    </div>

    <h3 class="course-card__title">{title}</h3>

    <p class="course-card__desc">{description}</p>

    <p
      class="course-card__meta"
      aria-label={`${chapterCount} chapters${hoursLabel ? `, ${hoursLabel}` : ''}${revisionLabel ? `, ${revisionLabel}` : ''}, ${difficulty}`}
    >
      {hoursLabel && <span>{hoursLabel}</span>}
      {hoursLabel && revisionLabel && <span class="course-card__meta-sep" aria-hidden="true">·</span>}
      {revisionLabel && <span>{revisionLabel}</span>}
      {!hoursLabel && !revisionLabel && (
        <span class="course-card__meta-dim">{isComingSoon ? 'Coming soon' : difficulty}</span>
      )}
    </p>

    <span class="course-card__progress" hidden></span>
  </Wrapper>
</li>

<style>
  .course-card-cell {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
  }

  .course-card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 0.875rem;
    padding: 1.125rem 1.25rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color 150ms ease,
      background 150ms ease,
      transform 150ms ease;
  }
  .course-card:hover,
  .course-card:focus-visible {
    border-color: var(--color-border-strong);
  }
  a.course-card:hover,
  a.course-card:focus-visible {
    text-decoration: none;
  }
  .course-card--inactive {
    opacity: 0.55;
    cursor: default;
  }
  .course-card--inactive:hover,
  .course-card--inactive:focus-visible {
    border-color: var(--color-border);
  }

  /* ---------- Head row: badge + chapter count ---------- */
  .course-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    min-height: 1.875rem;
  }

  .course-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.875rem;
    height: 1.875rem;
    padding: 0 0.4375rem;
    border-radius: 0.375rem;
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
  }
  .course-card__badge-img {
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 0.375rem;
    background: var(--color-surface-muted);
    padding: 0.25rem;
  }

  .course-card__count {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4375rem;
    color: var(--color-text-muted);
    font-family: var(--font-serif), Georgia, serif;
  }
  .course-card__count-n {
    font-size: 1.375rem;
    font-weight: 400;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .course-card__count-label {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .course-card__pill {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    background: var(--color-surface-muted);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  /* ---------- Body ---------- */
  .course-card__title {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
  }

  .course-card__desc {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.55;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .course-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4375rem;
    align-items: center;
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
  }
  .course-card__meta-sep {
    opacity: 0.5;
  }
  .course-card__meta-dim {
    text-transform: capitalize;
  }

  .course-card__progress {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
  }
  .course-card__progress[hidden] {
    display: none;
  }

  .course-card--complete .course-card__progress::before {
    content: '✓ ';
  }
</style>
