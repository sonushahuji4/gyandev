---
/**
 * ChapterCard — small featured chapter tile used by `FeaturedStrip`.
 *
 * Anatomy (DevNotes-style, Sprint 7):
 *   COURSE · SECTION          (overline, small caps, muted)
 *   Chapter title             (serif, Instrument Serif)
 *   Two-line excerpt          (muted)
 *   Difficulty · N min        (meta row)
 *
 * Whole-card anchor targets the Full Notes URL. Keyboard-accessible via
 * native `<a>` focus.
 */
import type { CollectionEntry } from 'astro:content';
import { chapterUrl } from '../../../lib/routes';

export interface Props {
  chapter: CollectionEntry<'chapters'>;
  course: CollectionEntry<'courses'>;
  courseSlug: string;
  chapterSlug: string;
  /** Optional overline section — falls back to the course title. */
  section?: string;
}

const { chapter, course, courseSlug, chapterSlug, section } = Astro.props;
const { title, description, difficulty, readingMinutes } = chapter.data;
const overline = section ?? course.data.title;
const courseIcon = (course.data.icon ?? '').startsWith('/') ? '' : (course.data.icon ?? '');
---

<li class="chapter-card-cell">
  <a class="chapter-card" href={chapterUrl(courseSlug, chapterSlug)}>
    <p class="chapter-card__overline">
      {courseIcon && <span class="chapter-card__icon" aria-hidden="true">{courseIcon}</span>}
      {overline}
    </p>
    <h3 class="chapter-card__title">{title}</h3>
    <p class="chapter-card__excerpt">{description}</p>
    <p class="chapter-card__meta">
      <span class="chapter-card__difficulty">{difficulty}</span>
      <span aria-hidden="true">·</span>
      <span>{readingMinutes} min</span>
    </p>
  </a>
</li>

<style>
  .chapter-card-cell {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
  }

  .chapter-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    padding: 1.125rem 1.25rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: inherit;
    text-decoration: none;
    transition: border-color 150ms ease, background 150ms ease;
  }
  .chapter-card:hover,
  .chapter-card:focus-visible {
    border-color: var(--color-border-strong);
    text-decoration: none;
  }

  .chapter-card__overline {
    margin: 0 0 0.125rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .chapter-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.125rem;
    height: 1.125rem;
    padding: 0 0.25rem;
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0;
  }

  .chapter-card__title {
    margin: 0;
    font-family: var(--font-serif), Georgia, serif;
    font-weight: 400;
    font-size: 1.25rem;
    line-height: 1.2;
    color: var(--color-text);
    letter-spacing: -0.005em;
  }

  .chapter-card__excerpt {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .chapter-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4375rem;
    align-items: center;
    margin: 0;
    padding-top: 0.375rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  .chapter-card__difficulty {
    text-transform: capitalize;
    padding: 0.125rem 0.4375rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface-muted);
    color: var(--color-text);
  }
  .chapter-card__meta span[aria-hidden="true"] {
    opacity: 0.5;
  }
</style>
