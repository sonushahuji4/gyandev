---
/**
 * ChapterCard — single chapter tile used by FeaturedStrip (PR-4.2, home.md
 * Step 9). Whole-card anchor targets the Full Notes URL. Keyboard-accessible
 * via native `<a>` focus.
 *
 * Props:
 *   chapter      — the chapter entry (`title`, `description`, `difficulty`,
 *                  `readingMinutes`).
 *   course       — the parent course entry. Its `title` appears as a small
 *                  muted label above the chapter title.
 *   courseSlug   — URL slug (first id segment, e.g. `"javascript"`).
 *   chapterSlug  — chapter folder name (e.g. `"closures"`).
 */
import type { CollectionEntry } from 'astro:content';
import { chapterUrl, courseUrl } from '../../../lib/routes';

export interface Props {
  chapter: CollectionEntry<'chapters'>;
  course: CollectionEntry<'courses'>;
  courseSlug: string;
  chapterSlug: string;
}

const { chapter, course, courseSlug, chapterSlug } = Astro.props;
const { title, description, difficulty, readingMinutes } = chapter.data;
---

<li class="chapter-card-cell">
  <article class="chapter-card">
    <a
      class="chapter-card__course"
      href={courseUrl(courseSlug)}
      aria-label={`${course.data.title} course overview`}
    >
      {course.data.title}
    </a>
    <h3 class="chapter-card__title">
      <a href={chapterUrl(courseSlug, chapterSlug)}>{title}</a>
    </h3>
    <p class="chapter-card__excerpt">{description}</p>
    <p class="chapter-card__meta">
      <span class="chapter-card__difficulty">{difficulty}</span>
      <span aria-hidden="true">·</span>
      <span>{readingMinutes} min read</span>
    </p>
  </article>
</li>

<style>
  .chapter-card-cell {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
  }

  .chapter-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }
  .chapter-card:hover,
  .chapter-card:focus-within {
    border-color: var(--color-border-strong, var(--color-border));
    box-shadow: 0 2px 14px -4px rgb(0 0 0 / 0.08);
  }

  .chapter-card__course {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .chapter-card__course:hover,
  .chapter-card__course:focus-visible {
    color: var(--color-text);
    text-decoration: underline;
  }

  .chapter-card__title {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .chapter-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }
  .chapter-card__title a:hover,
  .chapter-card__title a:focus-visible {
    text-decoration: underline;
  }

  .chapter-card__excerpt {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .chapter-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .chapter-card__difficulty {
    text-transform: capitalize;
  }
  .chapter-card__meta span[aria-hidden="true"] {
    opacity: 0.5;
  }
</style>
