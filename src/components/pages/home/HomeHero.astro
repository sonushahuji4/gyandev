---
/**
 * HomeHero — H1 + tagline + CTAs. Owns the document's single H1.
 *
 * Design direction (PR-Sprint-7 DevNotes revamp): minimalist, typography-
 * forward hero on a warm near-black background with a serif-italic accent word.
 * `Instrument Serif` is loaded only on this page via `includeSerif={true}` on
 * PageShell (ratification R2); all other text remains Inter.
 *
 * The primary CTA target is hardcoded to `/courses/nodejs` — roadmap Q#29
 * (Phase 2 extracts `featuredCourseSlug` into a site-level config).
 */
import { courseUrl } from '../../../lib/routes';

const FEATURED_COURSE_SLUG = 'nodejs';
const FEATURED_COURSE_LABEL = 'Node.js';
---

<header class="home-hero">
  <p class="home-hero__overline">CLEAR · DEEP · SHAREABLE</p>

  <h1 class="home-hero__title">
    Notes that actually <em class="home-hero__accent">stick.</em>
  </h1>

  <p class="home-hero__tagline">
    Every chapter, three ways: a <strong>deep read</strong> when you have an hour, a
    <strong>quick revision</strong> before the interview, and a <strong>flow diagram</strong>
    for the moments you just need to recall.
  </p>

  <div class="home-hero__ctas">
    <a class="home-hero__cta home-hero__cta--primary" href={courseUrl(FEATURED_COURSE_SLUG)}>
      Start with {FEATURED_COURSE_LABEL} →
    </a>
    <a class="home-hero__cta home-hero__cta--secondary" href="/courses">
      Browse all courses
    </a>
  </div>
</header>

<style>
  .home-hero {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 3.5rem 0 2.5rem;
    text-align: left;
    max-width: 44rem;
  }

  .home-hero__overline {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .home-hero__title {
    margin: 0;
    font-family: var(--font-serif), Georgia, serif;
    font-weight: 400;
    font-size: clamp(2.75rem, 7vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }

  .home-hero__accent {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 400;
  }

  .home-hero__tagline {
    max-width: 40rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.65;
  }
  .home-hero__tagline strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .home-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .home-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    font-weight: 500;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
  }

  .home-hero__cta--primary {
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border: 1px solid var(--color-accent);
  }
  .home-hero__cta--primary:hover,
  .home-hero__cta--primary:focus-visible {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--color-accent-fg);
  }

  .home-hero__cta--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border-strong);
  }
  .home-hero__cta--secondary:hover,
  .home-hero__cta--secondary:focus-visible {
    background: var(--color-surface-muted);
  }

  @media (min-width: 48rem) {
    .home-hero {
      padding: 4.5rem 0 3rem;
      gap: 1.5rem;
    }
    .home-hero__tagline {
      font-size: 1.0625rem;
    }
  }
</style>
