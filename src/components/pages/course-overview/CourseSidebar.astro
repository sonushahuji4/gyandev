---
/**
 * CourseSidebar — right-rail stack on `lg+` viewports (DevNotes revamp).
 *
 * Stacks three primary cards per the new design:
 *   1. `Prerequisites` — ↳ Course · Chapter links (structured from
 *      `course.data.prerequisiteChapters`).
 *   2. `DownloadsCard`  — Full / Revision / Flow download placeholders.
 *   3. `RelatedCourses` — ↳ Course Name links to siblings.
 *
 * Progress + Contribute are retained as auxiliary blocks beneath the three
 * primary cards so PR-4.1's reading-progress affordance survives the visual
 * refresh. Below `lg` they continue to stack naturally.
 *
 * GitHub URL shape is the same as the previous iteration — identical repo,
 * identical edit/issue patterns.
 */
import type { CollectionEntry } from 'astro:content';
import ProgressWidget from './ProgressWidget.astro';
import Prerequisites from './Prerequisites.astro';
import DownloadsCard from './DownloadsCard.astro';
import RelatedCourses from './RelatedCourses.astro';

export interface Props {
  courseSlug: string;
  total: number;
  related: CollectionEntry<'courses'>[];
  prerequisiteChapters: {
    courseSlug: string;
    chapterSlug: string;
    title: string;
  }[];
  downloads?: {
    full?: string;
    revision?: string;
    flow?: string;
  };
  /** Relative path within `src/content/courses/` for the GitHub edit link. */
  courseContentPath: string;
}

const {
  courseSlug,
  total,
  related,
  prerequisiteChapters,
  downloads,
  courseContentPath,
} = Astro.props as Props;

const GITHUB_REPO = 'https://github.com/sonushahuji4/gyandev';
const editUrl = `${GITHUB_REPO}/edit/main/src/content/courses/${courseContentPath}`;
const issueUrl = `${GITHUB_REPO}/issues/new?title=${encodeURIComponent(
  `[${courseSlug}] `,
)}&labels=content`;
---

<aside class="course-sidebar" aria-label="Course info">
  <Prerequisites prerequisiteChapters={prerequisiteChapters} />
  <DownloadsCard downloads={downloads} />
  <RelatedCourses related={related} />

  {total > 0 && (
    <div class="course-sidebar__progress">
      <ProgressWidget courseSlug={courseSlug} total={total} />
    </div>
  )}

  <section class="course-sidebar__contribute" aria-labelledby="contribute-heading">
    <h3 id="contribute-heading" class="course-sidebar__heading">CONTRIBUTE</h3>
    <ul class="course-sidebar__list">
      <li>
        <a href={editUrl} rel="noopener noreferrer" target="_blank">Edit course →</a>
      </li>
      <li>
        <a href={issueUrl} rel="noopener noreferrer" target="_blank">Report issue →</a>
      </li>
    </ul>
  </section>
</aside>

<style>
  .course-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .course-sidebar__progress {
    padding: 0 0 0 1rem;
    border-left: 1px solid var(--color-border);
  }

  .course-sidebar__contribute {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0 0 0 1rem;
    border-left: 1px solid var(--color-border);
  }

  .course-sidebar__heading {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .course-sidebar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9375rem;
  }

  .course-sidebar__list a {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .course-sidebar__list a:hover,
  .course-sidebar__list a:focus-visible {
    color: var(--color-accent);
    border-bottom-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
  }
</style>
