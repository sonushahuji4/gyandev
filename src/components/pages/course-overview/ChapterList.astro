---
/**
 * ChapterList — wraps one or more `SeasonGroup`s (PR-4.1).
 *
 * Falls back to a flat, unadorned list when the course has no season
 * grouping (per roadmap Q#23 — single-season courses should not show a
 * decorative "Season 1" header). This keeps the page quiet for small courses.
 *
 * The `<section>` carries `aria-label="Chapters"` for screen readers so
 * landing-on-list navigation announces the list purpose even when no season
 * headers are rendered.
 */
import SeasonGroup from './SeasonGroup.astro';
import type { CourseChapterRef } from '../../../lib/courses/bySlug';

export interface Props {
  groups: Map<number, CourseChapterRef[]>;
  courseSlug: string;
}

const { groups, courseSlug } = Astro.props;

// When there is exactly one group AND it's the default "Season 1" bucket,
// suppress the season header to render a flat list. Authors who intentionally
// label chapters `season: 1` get the same treatment because the effect is
// identical visually — the course is single-seasoned.
const entries = [...groups.entries()];
const isFlat = entries.length <= 1;

let runningOrder = 1;
---

<section class="chapter-list" aria-label="Chapters">
  {entries.map(([season, chapters]) => {
    const startOrder = runningOrder;
    runningOrder += chapters.length;
    return (
      <SeasonGroup
        season={season}
        chapters={chapters}
        courseSlug={courseSlug}
        startOrder={startOrder}
        hideHeader={isFlat}
      />
    );
  })}

  {entries.length === 0 && (
    <p class="chapter-list__empty">First chapters coming soon.</p>
  )}
</section>

<style>
  .chapter-list {
    margin: 0;
  }
  .chapter-list__empty {
    margin: 1rem 0 0;
    padding: 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    text-align: center;
  }
</style>
