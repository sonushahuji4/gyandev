---
/**
 * ChapterList — wraps the ordered chapter rows with a `CHAPTERS` overline
 * (DevNotes revamp). Delegates season bucketing to `SeasonGroup`; when a
 * course has a single (default) season the season header is suppressed for
 * a flat list layout.
 */
import SeasonGroup from './SeasonGroup.astro';
import type { CourseChapterRef } from '../../../lib/courses/bySlug';

export interface Props {
  groups: Map<number, CourseChapterRef[]>;
  courseSlug: string;
}

const { groups, courseSlug } = Astro.props;

const entries = [...groups.entries()];

// Single-season courses usually render as a flat list (no header).
// Courses that declare a `seasonTitle` on any chapter opt in to showing
// the named header even when they have only one season.
const hasNamedSeason = entries.some(([, chapters]) =>
  chapters.some((c) => c.chapter.data.seasonTitle),
);
const isFlat = entries.length <= 1 && !hasNamedSeason;

let runningOrder = 1;
---

<section class="chapter-list" aria-labelledby="chapter-list-heading">
  <p class="chapter-list__overline">CHAPTERS</p>
  <h2 id="chapter-list-heading" class="sr-only">Chapters</h2>

  {entries.map(([season, chapters]) => {
    const startOrder = runningOrder;
    runningOrder += chapters.length;
    return (
      <SeasonGroup
        season={season}
        chapters={chapters}
        courseSlug={courseSlug}
        startOrder={startOrder}
        hideHeader={isFlat}
      />
    );
  })}

  {entries.length === 0 && (
    <p class="chapter-list__empty">First chapters coming soon.</p>
  )}
</section>

<style>
  .chapter-list {
    margin: 0;
  }

  .chapter-list__overline {
    margin: 0 0 1rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .chapter-list__empty {
    margin: 1rem 0 0;
    padding: 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    text-align: center;
  }
</style>
