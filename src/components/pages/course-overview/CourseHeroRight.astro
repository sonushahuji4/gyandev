---
/**
 * Course hero — right column (DevNotes revamp).
 *
 * Two stacked CTAs:
 *   1. **Resume CTA** — hidden on first paint; the hydration script reveals it
 *      when the course has progress and rewrites its label + href to point at
 *      the "current" chapter. Shown as a solid green button that reads
 *      `"Resume: <chapterTitle> →"`. Uses the same `data-cta="resume"`
 *      contract as the prior design so `course-overview-hydrate.ts` still
 *      drives it — but the label hydrates from `lastRead.chapterTitle` now.
 *   2. **Start CTA** — always visible until the course is 100% complete.
 *      Outline button styled in the DevNotes palette. Reads `"Start from Ch. 1"`.
 *
 * Both CTAs are real `<a href>` so the page works without JS. Hiding Resume
 * on SSR avoids a flash at zero-progress — the common case.
 */
import { chapterUrl, courseUrl } from '../../../lib/routes';

export interface Props {
  courseSlug: string;
  /** Slug of the first published chapter. When absent, both CTAs hide. */
  firstChapterSlug?: string;
}

const { courseSlug, firstChapterSlug } = Astro.props;

const startHref = firstChapterSlug ? chapterUrl(courseSlug, firstChapterSlug) : undefined;
const resumeHref = startHref;
const urlBase = courseUrl(courseSlug);
const hasChapters = Boolean(firstChapterSlug);
---

<div class="course-hero-right" data-course-slug={courseSlug}>
  <div class="course-hero-right__ctas">
    <a
      class="course-hero-right__btn course-hero-right__btn--primary"
      data-cta="resume"
      data-course-slug={courseSlug}
      data-url-base={urlBase}
      href={resumeHref}
      hidden
    >
      <span class="course-hero-right__btn-label">
        <span class="course-hero-right__btn-prefix">Resume:</span>
        <span data-cta-label>Continue</span>
      </span>
      <span aria-hidden="true" class="course-hero-right__btn-arrow">→</span>
    </a>

    <a
      class="course-hero-right__btn course-hero-right__btn--secondary"
      data-cta="start"
      href={startHref}
      hidden={!hasChapters}
    >
      Start from Ch. 1
    </a>
  </div>

  <div
    id="complete-banner"
    class="course-hero-right__banner"
    role="status"
    hidden
  >
    <p class="course-hero-right__banner-title">Course complete</p>
    <p class="course-hero-right__banner-body">You&apos;ve read every chapter. Revisit anytime.</p>
  </div>
</div>

<style>
  .course-hero-right {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: stretch;
    width: 100%;
  }
  @media (min-width: 64rem) {
    .course-hero-right {
      align-items: flex-end;
      width: auto;
      min-width: 16rem;
    }
  }

  .course-hero-right__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }
  @media (min-width: 64rem) {
    .course-hero-right__ctas {
      min-width: 14rem;
    }
  }

  .course-hero-right__btn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.6875rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    min-height: 2.5rem;
    transition: background-color 150ms ease, border-color 150ms ease, color 150ms ease;
    white-space: nowrap;
  }
  .course-hero-right__btn[hidden] {
    display: none;
  }

  .course-hero-right__btn--primary {
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-color: var(--color-accent);
  }
  .course-hero-right__btn--primary:hover,
  .course-hero-right__btn--primary:focus-visible {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--color-accent-fg);
  }

  .course-hero-right__btn--secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border-strong);
    justify-content: center;
  }
  .course-hero-right__btn--secondary:hover,
  .course-hero-right__btn--secondary:focus-visible {
    background: var(--color-surface-muted);
    border-color: var(--color-border-strong);
  }

  .course-hero-right__btn-label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.375rem;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }
  .course-hero-right__btn-prefix {
    font-weight: 500;
    opacity: 0.9;
  }
  .course-hero-right__btn-arrow {
    flex-shrink: 0;
  }

  .course-hero-right__banner {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface-muted);
    max-width: 22rem;
  }
  .course-hero-right__banner[hidden] {
    display: none;
  }
  .course-hero-right__banner-title {
    margin: 0 0 0.125rem;
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.9375rem;
  }
  .course-hero-right__banner-body {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
