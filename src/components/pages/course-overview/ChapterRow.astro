---
/**
 * ChapterRow — one `<li>` in the DevNotes chapter list (course-overview).
 *
 * Layout:
 *   [order numeral + completion check]  [title + excerpt]  [time + view dots]
 *
 * Columns:
 *   - Left: zero-padded order number in Instrument Serif italic, plus a
 *     completion icon. Icon starts as `○` (not read) and flips to `✓` for
 *     read or `●` for the current/resume target once the hydration script
 *     runs. `data-chapter-slug` is the hydration handle.
 *   - Middle: chapter title (row link) and muted `excerpt` (falls back to
 *     `description`).
 *   - Right: `"N min"` reading time and three availability dots — one each
 *     for Full / Revision / Flow (filled = available). Dot order matches
 *     spec §15.
 *
 * Coming-soon rows render with no link target and an inline
 * `"Coming soon"` badge in place of the availability dots. `aria-disabled`
 * keeps assistive tech from announcing them as actionable.
 */
import { chapterUrl } from '../../../lib/routes';
import type { ChapterAvailability } from '../../../lib/courses/bySlug';

export interface Props {
  title: string;
  excerpt: string;
  readingMinutes: number;
  courseSlug: string;
  chapterSlug: string;
  /** 1-based position used for the zero-padded order label. */
  orderLabel: number;
  availability: ChapterAvailability;
  /** `'coming-soon'` renders the row grayed + disabled. */
  status: 'published' | 'coming-soon' | 'draft';
}

const {
  title,
  excerpt,
  readingMinutes,
  courseSlug,
  chapterSlug,
  orderLabel,
  availability,
  status,
} = Astro.props;

const paddedOrder = String(orderLabel).padStart(2, '0');
const isComingSoon = status === 'coming-soon';

const VIEWS: Array<{ key: keyof ChapterAvailability; label: string }> = [
  { key: 'full',     label: 'Full Notes' },
  { key: 'revision', label: 'Quick Revision' },
  { key: 'flow',     label: 'Flow Diagram' },
];

const dotAriaLabel = VIEWS.map(
  ({ key, label }) =>
    `${label} ${availability[key] ? 'available' : 'not yet available'}`,
).join(', ');
---

<li
  class:list={['chapter-row', isComingSoon && 'chapter-row--coming-soon']}
  data-chapter-slug={chapterSlug}
  aria-disabled={isComingSoon ? 'true' : undefined}
>
  <div class="chapter-row__lead">
    <span class="chapter-row__order" aria-hidden="true">{paddedOrder}</span>
    <span
      class="chapter-row__icon"
      data-status="not-started"
      aria-label="Not started"
      role="img"
    >○</span>
  </div>

  <div class="chapter-row__body">
    {isComingSoon ? (
      <span class="chapter-row__title">{title}</span>
    ) : (
      <a class="chapter-row__link" href={chapterUrl(courseSlug, chapterSlug)}>
        <span class="chapter-row__title">{title}</span>
      </a>
    )}
    {excerpt && <p class="chapter-row__excerpt">{excerpt}</p>}
  </div>

  <div class="chapter-row__meta">
    <span class="chapter-row__time">{readingMinutes} min</span>
    {isComingSoon ? (
      <span class="chapter-row__soon" aria-label="Coming soon">coming soon</span>
    ) : (
      <span class="chapter-row__dots" aria-label={dotAriaLabel} role="img">
        {VIEWS.map(({ key }) => (
          <span
            class:list={['chapter-row__dot', !availability[key] && 'chapter-row__dot--empty']}
            aria-hidden="true"
          >{availability[key] ? '●' : '○'}</span>
        ))}
      </span>
    )}
  </div>
</li>

<style>
  .chapter-row {
    display: grid;
    grid-template-columns: 4.25rem minmax(0, 1fr) auto;
    align-items: start;
    gap: 0.75rem 1.25rem;
    padding: 1.125rem 0;
    border-top: 1px solid var(--color-border);
    list-style: none;
    position: relative;
    transition: background-color 160ms ease;
  }
  .chapter-row:first-child {
    border-top: none;
  }
  .chapter-row:not(.chapter-row--coming-soon):hover {
    background: color-mix(in srgb, var(--color-surface-muted) 55%, transparent);
  }

  /* Lead cell: order numeral + completion check, stacked horizontally. */
  .chapter-row__lead {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding-top: 0.125rem;
  }

  .chapter-row__order {
    font-family: var(--font-serif), Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.625rem;
    line-height: 1;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .chapter-row__icon {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1;
    min-width: 0.75rem;
    text-align: center;
  }
  .chapter-row__icon[data-status="read"] {
    color: var(--color-accent);
  }
  .chapter-row__icon[data-status="current"] {
    color: var(--color-accent);
  }

  .chapter-row__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .chapter-row__link {
    text-decoration: none;
    color: var(--color-text);
    display: inline-block;
    max-width: max-content;
  }
  .chapter-row__title {
    color: var(--color-text);
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.005em;
  }
  .chapter-row__link:hover .chapter-row__title,
  .chapter-row__link:focus-visible .chapter-row__title {
    color: var(--color-accent);
  }

  .chapter-row__excerpt {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
    max-width: 48rem;
  }

  /* Meta cell: reading time + dots OR coming-soon badge. */
  .chapter-row__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .chapter-row__time {
    font-variant-numeric: tabular-nums;
  }

  .chapter-row__dots {
    display: inline-flex;
    gap: 0.25rem;
    align-items: center;
  }
  .chapter-row__dot {
    color: var(--color-accent);
    font-size: 0.5rem;
    line-height: 1;
  }
  .chapter-row__dot--empty {
    color: var(--color-border-strong);
  }

  .chapter-row__soon {
    font-family: var(--font-serif), Georgia, serif;
    font-style: italic;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  /* Coming-soon row: grayed typography, no hover. */
  .chapter-row--coming-soon .chapter-row__title,
  .chapter-row--coming-soon .chapter-row__excerpt,
  .chapter-row--coming-soon .chapter-row__order,
  .chapter-row--coming-soon .chapter-row__icon {
    color: var(--color-text-muted);
    opacity: 0.75;
  }

  @media (max-width: 40rem) {
    .chapter-row {
      grid-template-columns: 3.25rem minmax(0, 1fr);
      gap: 0.5rem 0.875rem;
    }
    .chapter-row__order {
      font-size: 1.375rem;
    }
    .chapter-row__meta {
      grid-column: 2;
      padding-top: 0;
      margin-top: 0.25rem;
    }
  }
</style>
