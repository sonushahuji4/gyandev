---
/**
 * "Before You Start" prerequisites (PR-4.1).
 *
 * Spec §3 Section 4: free-text prerequisites from `course.data.prerequisites`.
 * `prerequisiteCourses` is an optional array of sibling course entries that
 * render as "See our <Course name>" links beneath the list. Automatic
 * text-to-course matching is a Phase 2 item per course-overview.md §13.
 *
 * Hidden when there are no prerequisites.
 */
import type { CollectionEntry } from 'astro:content';
import { courseUrl } from '../../../lib/routes';

export interface Props {
  prerequisites: string[];
  /** Optional curated list of sibling courses to link to. */
  prerequisiteCourses?: CollectionEntry<'courses'>[];
}

const { prerequisites, prerequisiteCourses = [] } = Astro.props;
const hasItems = prerequisites.length > 0;
const hasLinks = prerequisiteCourses.length > 0;
---

{hasItems && (
  <section class="prerequisites" aria-labelledby="prerequisites-heading">
    <h2 id="prerequisites-heading">Before You Start</h2>

    <p class="prerequisites__lead">You should be comfortable with:</p>

    <ul class="prerequisites__list">
      {prerequisites.map((item) => (
        <li>{item}</li>
      ))}
    </ul>

    {hasLinks && (
      <p class="prerequisites__links">
        {prerequisiteCourses.map((pre, i) => {
          const preSlug = pre.id.split('/')[0]!;
          return (
            <>
              {i > 0 && <span aria-hidden="true"> · </span>}
              <a href={courseUrl(preSlug)}>See our {pre.data.title} course →</a>
            </>
          );
        })}
      </p>
    )}
  </section>
)}

<style>
  .prerequisites {
    margin: 2rem 0 0;
  }
  .prerequisites h2 {
    font-size: var(--text-h2);
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .prerequisites__lead {
    margin: 0 0 0.5rem;
    color: var(--color-text-muted);
  }
  .prerequisites__list {
    margin: 0;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    color: var(--color-text);
    line-height: 1.55;
    max-width: 44rem;
  }
  .prerequisites__list li::marker {
    color: var(--color-text-muted);
  }
  .prerequisites__links {
    margin: 0.75rem 0 0;
    font-size: 0.9375rem;
  }
  .prerequisites__links a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prerequisites__links a:hover,
  .prerequisites__links a:focus-visible {
    color: var(--color-accent, var(--color-text));
  }
</style>
