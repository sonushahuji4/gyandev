---
/**
 * ProgressWidget — accessible per-course reading progress (PR-4.1).
 *
 * Renders `role="progressbar"` with `aria-valuemin="0"`, `aria-valuemax={total}`,
 * `aria-valuenow="0"`. The hydration script (`course-overview-hydrate.ts`)
 * updates:
 *   - `aria-valuenow` to the actual read count,
 *   - `.progress-widget__read` text,
 *   - `.progress-widget__fill` width (`${percent}%`).
 *
 * The server render is deliberately "0 of N" so the zero-JS experience is
 * correct. `data-course-slug` + `data-total` are the hydration contract.
 *
 * Flagged for promotion to `src/components/ui/ProgressWidget.astro` in
 * Phase 1.5 once the home page reuses it (roadmap §9).
 */

export interface Props {
  courseSlug: string;
  total: number;
}

const { courseSlug, total } = Astro.props;
---

<section class="progress-widget-section" aria-labelledby="progress-widget-heading">
  <h3 id="progress-widget-heading" class="progress-widget-section__title">Your Progress</h3>

  <div
    class="progress-widget"
    data-course-slug={courseSlug}
    data-total={total}
    role="progressbar"
    aria-valuemin="0"
    aria-valuemax={total}
    aria-valuenow="0"
    aria-label="Reading progress"
  >
    <p class="progress-widget__text">
      <span class="progress-widget__read" data-progress-read>0</span> of {total} read
    </p>
    <div class="progress-widget__bar" aria-hidden="true">
      <div class="progress-widget__fill" data-progress-fill style="width:0%"></div>
    </div>
  </div>
</section>

<style>
  .progress-widget-section {
    margin: 0;
  }
  .progress-widget-section__title {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .progress-widget {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .progress-widget__text {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }
  .progress-widget__bar {
    width: 100%;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-surface-muted);
    overflow: hidden;
  }
  .progress-widget__fill {
    height: 100%;
    background: var(--color-accent, var(--color-text));
    transition: width 200ms ease;
  }
</style>
