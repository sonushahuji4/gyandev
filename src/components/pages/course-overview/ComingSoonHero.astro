---
/**
 * ComingSoonHero — minimal layout for courses marked `status: 'coming-soon'`
 * (PR-4.1).
 *
 * Spec §11: renders course name, description, a "Coming soon" message, and a
 * link to the RSS feed as the Phase-1 notify-me stand-in (per task spec,
 * email signup is deferred). The parent page applies `noindex` via the
 * PageShell prop — this component just renders the body.
 */
import type { CollectionEntry } from 'astro:content';

export interface Props {
  course: CollectionEntry<'courses'>;
}

const { course } = Astro.props;
const { title, description, icon } = course.data;
---

<section class="coming-soon-hero" aria-labelledby="coming-soon-heading">
  {icon && (
    <img
      class="coming-soon-hero__icon"
      src={icon}
      alt=""
      width="96"
      height="96"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      aria-hidden="true"
    />
  )}

  <p class="coming-soon-hero__badge">Coming soon</p>
  <h1 id="coming-soon-heading" class="coming-soon-hero__title">{title}</h1>
  <p class="coming-soon-hero__desc">{description}</p>

  <p class="coming-soon-hero__body">
    This course isn&apos;t ready yet. Subscribe to the feed and you&apos;ll see it the moment the first chapter lands.
  </p>

  <div class="coming-soon-hero__ctas">
    <a class="coming-soon-hero__btn" href="/rss.xml">Get notified via RSS →</a>
    <a class="coming-soon-hero__btn coming-soon-hero__btn--secondary" href="/courses">
      Browse other courses
    </a>
  </div>
</section>

<style>
  .coming-soon-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 3rem 1rem;
    max-width: 36rem;
    margin: 0 auto;
  }
  .coming-soon-hero__icon {
    width: 5rem;
    height: 5rem;
    border-radius: 1rem;
    background: var(--color-surface-muted);
    padding: 0.5rem;
  }
  .coming-soon-hero__badge {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }
  .coming-soon-hero__title {
    margin: 0;
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-text);
  }
  .coming-soon-hero__desc {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    line-height: 1.5;
  }
  .coming-soon-hero__body {
    margin: 0.5rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    max-width: 28rem;
  }
  .coming-soon-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .coming-soon-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    background: var(--color-accent, #17150f);
    color: var(--color-surface, #fafaf7);
    border: 1px solid var(--color-accent, #17150f);
    min-height: 2.75rem;
  }
  .coming-soon-hero__btn--secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .coming-soon-hero__btn--secondary:hover,
  .coming-soon-hero__btn--secondary:focus-visible {
    border-color: var(--color-border-strong);
    background: var(--color-surface-muted);
  }
</style>
