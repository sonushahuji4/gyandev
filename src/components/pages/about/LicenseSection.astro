---
/**
 * LicenseSection — explains the dual-license story. Spec §3 Section 5.
 *
 * Content is static; kept in an `.astro` file rather than MDX because it
 * rarely changes and two visitors would be surprised to see a paywall.
 */

const REPO_URL = 'https://github.com/sonushahuji4/gyandev';
---

<section class="license" aria-labelledby="license-h">
  <h2 id="license-h">Open source, open content</h2>
  <p>GyanDev is free forever. The licenses make that contractual, not a promise:</p>
  <ul class="license__list">
    <li>
      <strong>Content:</strong> <a
        href="https://creativecommons.org/licenses/by-sa/4.0/"
        target="_blank"
        rel="noopener noreferrer">Creative Commons BY-SA 4.0</a
      >. Share, adapt, and build on it — as long as you credit the source and
      keep derivatives under the same license.
    </li>
    <li>
      <strong>Code:</strong> <a
        href="https://opensource.org/licenses/MIT"
        target="_blank"
        rel="noopener noreferrer">MIT</a
      >. Take the site's code and reuse it however you like.
    </li>
    <li>
      <strong>Hosting:</strong> the full source, issue tracker, and history
      live on GitHub. Pull requests welcome.
    </li>
  </ul>
  <p>
    <a class="license__repo" href={REPO_URL} target="_blank" rel="noopener noreferrer">
      View the repository on GitHub →
    </a>
  </p>
</section>

<style>
  .license {
    margin: 0 0 3rem;
  }
  .license__list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .license__repo {
    font-weight: 500;
  }
</style>
