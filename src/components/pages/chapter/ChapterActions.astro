---
/**
 * Action row in the chapter header — Bookmark, Mark as read, Share, Print,
 * Edit on GitHub.
 *
 * Bookmark + Mark-as-read are server-rendered with `aria-pressed="false"` and
 * hydrated by `src/scripts/chapter-hydrate.ts` which reads the per-course
 * progress + bookmarks envelopes via `progressKey()` / `bookmarksKey()`
 * (storage.ts builders, per roadmap §2.R1).
 *
 * Share + Print are icon-only controls handled by a small inline script
 * (kept here so the hydration file doesn't need to know about them). Share
 * uses `navigator.share` when available and falls back to copying the URL.
 */
interface Props {
  editUrl: string;
  shareUrl: string;
  shareTitle: string;
}

const { editUrl, shareUrl, shareTitle } = Astro.props;
---

<div class="chapter-actions" data-chapter-actions>
  <button
    type="button"
    class="chapter-actions__btn"
    data-action="bookmark"
    aria-pressed="false"
    aria-label="Bookmark this chapter"
    title="Bookmark"
  >
    <span class="chapter-actions__icon" aria-hidden="true">☆</span>
    <span class="chapter-actions__label">Bookmark</span>
  </button>

  <button
    type="button"
    class="chapter-actions__btn"
    data-action="mark-read"
    aria-pressed="false"
    aria-label="Mark as read"
    title="Mark as read"
  >
    <span class="chapter-actions__icon" aria-hidden="true">✓</span>
    <span class="chapter-actions__label">Mark as read</span>
  </button>

  <button
    type="button"
    class="chapter-actions__btn chapter-actions__btn--icon"
    data-action="share"
    data-share-url={shareUrl}
    data-share-title={shareTitle}
    aria-label="Share this chapter"
    title="Share"
  >
    <span class="chapter-actions__icon" aria-hidden="true">↗</span>
  </button>

  <button
    type="button"
    class="chapter-actions__btn chapter-actions__btn--icon"
    data-action="print"
    aria-label="Print this chapter"
    title="Print"
  >
    <span class="chapter-actions__icon" aria-hidden="true">⎙</span>
  </button>

  <a
    class="chapter-actions__btn chapter-actions__btn--icon chapter-actions__btn--link"
    href={editUrl}
    rel="noopener noreferrer"
    target="_blank"
    aria-label="Edit on GitHub"
    title="Edit on GitHub"
  >
    <span class="chapter-actions__icon" aria-hidden="true">✎</span>
  </a>
</div>

<script>
  function bindActions(root: Document | HTMLElement): void {
    for (const btn of root.querySelectorAll<HTMLButtonElement>('[data-chapter-actions] [data-action="share"]')) {
      if (btn.dataset.bound === 'true') continue;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', async () => {
        const url = btn.dataset.shareUrl ?? location.href;
        const title = btn.dataset.shareTitle ?? document.title;
        if (typeof navigator !== 'undefined' && 'share' in navigator) {
          try { await navigator.share({ title, url }); return; } catch { /* user cancelled */ }
        }
        try {
          await navigator.clipboard.writeText(url);
          btn.setAttribute('title', 'Link copied');
          setTimeout(() => btn.setAttribute('title', 'Share'), 1500);
        } catch { /* clipboard may be unavailable */ }
      });
    }
    for (const btn of root.querySelectorAll<HTMLButtonElement>('[data-chapter-actions] [data-action="print"]')) {
      if (btn.dataset.bound === 'true') continue;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', () => window.print());
    }
  }
  bindActions(document);
  document.addEventListener('astro:page-load', () => bindActions(document));
</script>

<style>
  .chapter-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.1rem;
  }
  .chapter-actions__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 2.5rem;
    padding: 0 0.75rem;
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font: inherit;
    font-size: 0.825rem;
    text-decoration: none;
    cursor: pointer;
  }
  .chapter-actions__btn:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
    background: var(--color-surface-muted);
  }
  .chapter-actions__btn[aria-pressed="true"] {
    background: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .chapter-actions__btn--icon {
    width: 2.5rem;
    min-height: 2.5rem;
    padding: 0;
    justify-content: center;
  }
  .chapter-actions__icon {
    font-size: 1rem;
    line-height: 1;
  }
  .chapter-actions__btn--link { text-decoration: none; }

  @media (max-width: 40rem) {
    .chapter-actions__btn:not(.chapter-actions__btn--icon) .chapter-actions__label {
      display: none;
    }
    .chapter-actions__btn:not(.chapter-actions__btn--icon) {
      width: 2.5rem;
      padding: 0;
      justify-content: center;
    }
  }
</style>
