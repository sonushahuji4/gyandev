---
/**
 * ChapterRenderer — the single MDX renderer used by every chapter view.
 *
 * Per PHASE-1-ROADMAP §9, this component is created at the shared
 * `src/components/content/` path directly (no page-scope → ui promotion
 * step) because any future prose route (docs, blog) will use the same
 * MDX component map.
 *
 * The map is intentionally small in Phase 1 — Shiki rendering of code
 * fences is handled by `rehype-pretty-code` at build time (see
 * `astro.config.mjs`), so no per-element override is needed for `<pre>`.
 *
 * Custom components authors can use without importing in every MDX:
 *   - `<Figure>` — pass-through to FigureDescribed for accessible diagrams
 *   - `<MermaidCaption>` — Flow-only Mermaid wrapper (chapter component)
 *   - `<Callout>` — tip/warning/insight/quote/mnemonic accent block
 *   - `<RevisionCard>` — bordered card used on Quick Revision view
 *   - `<FlowLegendGrid>` — legend grid below a Mermaid flowchart
 *   - `<CodeTabs>` — in-body tabs for code variants (e.g. Python / TypeScript)
 *
 * Authors still need an explicit `import` for components that take
 * non-trivial props or live outside the chapter scope; the map handles
 * the universal cases.
 */
import FigureDescribed from '../a11y/FigureDescribed.astro';
import MermaidCaption from '../pages/chapter/MermaidCaption.astro';
import Callout from './Callout.astro';
import RevisionCard from './RevisionCard.astro';
import FlowLegendGrid from './FlowLegendGrid.astro';
import CodeTabs from './CodeTabs.astro';

interface Props {
  /** The MDX `<Content />` factory returned by `await render(entry)`. */
  Content: any;
  /** Optional per-call overrides merged onto the default map. */
  components?: Record<string, any>;
}

const { Content, components = {} } = Astro.props;

const defaultMap: Record<string, any> = {
  Figure: FigureDescribed,
  MermaidCaption,
  Callout,
  RevisionCard,
  FlowLegendGrid,
  CodeTabs,
};

const merged = { ...defaultMap, ...components };
---

<Content components={merged} />
