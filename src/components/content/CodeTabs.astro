---
/**
 * CodeTabs — in-body tab switcher for code variants (typically a Python /
 * TypeScript split). Registered in `ChapterRenderer.astro` so authors can
 * use `<CodeTabs>` from MDX without importing.
 *
 * Authoring:
 *
 *   <CodeTabs tabs={["Python", "TypeScript"]}>
 *   <Fragment slot="tab-0">
 *
 *   ```python
 *   def merge(intervals): ...
 *   ```
 *
 *   </Fragment>
 *   <Fragment slot="tab-1">
 *
 *   ```ts
 *   function merge(intervals) { ... }
 *   ```
 *
 *   </Fragment>
 *   </CodeTabs>
 *
 * Blank lines around the fences are required so MDX parses them as fenced
 * code blocks (Shiki highlighting continues to work end-to-end via
 * rehype-pretty-code).
 *
 * First tab is active on mount. Switching is client-side only — every
 * panel is rendered; inactive ones use the native `hidden` attribute, so
 * the UI degrades cleanly to a stack if JS fails.
 */

interface Props {
  /** Tab labels, one per slot `tab-0`, `tab-1`, … */
  tabs: string[];
  /** Optional aria-label override for the tablist. */
  ariaLabel?: string;
  class?: string;
}

const {
  tabs,
  ariaLabel = 'Code variants',
  class: className,
} = Astro.props;
---

<div class:list={['codetabs', className]} data-codetabs>
  <div class="codetabs__tablist" role="tablist" aria-label={ariaLabel}>
    {tabs.map((label, i) => (
      <button
        type="button"
        role="tab"
        class:list={['codetabs__tab', i === 0 && 'is-active']}
        aria-selected={i === 0 ? 'true' : 'false'}
        tabindex={i === 0 ? 0 : -1}
        data-tab-idx={i}
      >{label}</button>
    ))}
  </div>
  <div class="codetabs__panels">
    {tabs.length > 0 && (
      <div class:list={['codetabs__panel', 'is-active']} role="tabpanel" data-panel-idx={0}>
        <slot name="tab-0" />
      </div>
    )}
    {tabs.length > 1 && (
      <div class="codetabs__panel" role="tabpanel" data-panel-idx={1} hidden>
        <slot name="tab-1" />
      </div>
    )}
    {tabs.length > 2 && (
      <div class="codetabs__panel" role="tabpanel" data-panel-idx={2} hidden>
        <slot name="tab-2" />
      </div>
    )}
    {tabs.length > 3 && (
      <div class="codetabs__panel" role="tabpanel" data-panel-idx={3} hidden>
        <slot name="tab-3" />
      </div>
    )}
    {tabs.length > 4 && (
      <div class="codetabs__panel" role="tabpanel" data-panel-idx={4} hidden>
        <slot name="tab-4" />
      </div>
    )}
  </div>
</div>

<style>
  .codetabs {
    margin: 1.75em 0;
  }
  .codetabs__tablist {
    display: inline-flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .codetabs__tablist::-webkit-scrollbar { display: none; }

  .codetabs__tab {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid transparent;
    border-bottom: 2px solid transparent;
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.25;
    cursor: pointer;
    border-radius: 8px 8px 0 0;
    white-space: nowrap;
    transition: color 160ms ease, background-color 160ms ease,
      border-color 160ms ease;
  }
  .codetabs__tab:hover {
    color: var(--color-text);
    background: var(--color-surface-muted);
  }
  .codetabs__tab.is-active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
  }
  .codetabs__tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .codetabs__panels {
    margin-top: 0;
  }
  .codetabs__panel > :global(pre) {
    margin-top: 1rem;
  }
</style>

<script>
  function bindCodeTabs(root: HTMLElement): void {
    if (root.dataset.codetabsBound === 'true') return;
    root.dataset.codetabsBound = 'true';

    const tabs = Array.from(
      root.querySelectorAll<HTMLElement>('[role="tab"]'),
    );
    const panels = Array.from(
      root.querySelectorAll<HTMLElement>('[role="tabpanel"]'),
    );

    function activate(i: number): void {
      tabs.forEach((t, idx) => {
        const active = idx === i;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.setAttribute('tabindex', active ? '0' : '-1');
      });
      panels.forEach((p, idx) => {
        const active = idx === i;
        p.classList.toggle('is-active', active);
        if (active) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        activate(i);
        tab.focus();
      });
    });

    root.addEventListener('keydown', (event: KeyboardEvent) => {
      const current = document.activeElement as HTMLElement | null;
      const idx = current ? tabs.indexOf(current) : -1;
      if (idx < 0) return;

      let next = idx;
      switch (event.key) {
        case 'ArrowRight':
        case 'ArrowDown':
          next = (idx + 1) % tabs.length;
          break;
        case 'ArrowLeft':
        case 'ArrowUp':
          next = (idx - 1 + tabs.length) % tabs.length;
          break;
        case 'Home':
          next = 0;
          break;
        case 'End':
          next = tabs.length - 1;
          break;
        default:
          return;
      }
      event.preventDefault();
      activate(next);
      tabs[next]?.focus();
    });
  }

  function bindAll(): void {
    for (const el of document.querySelectorAll<HTMLElement>('[data-codetabs]')) {
      bindCodeTabs(el);
    }
  }

  bindAll();
  document.addEventListener('astro:page-load', bindAll);
</script>
