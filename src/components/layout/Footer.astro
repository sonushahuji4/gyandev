---
/**
 * Footer — global site footer. DevNotes-style revamp (Sprint 7):
 *
 *   GyanDev.                     CONTENT         PROJECT         LEGAL
 *   One-line tagline             All courses     Contribute      About
 *                                Tracks          GitHub          Privacy
 *                                Review          Changelog       Terms
 *                                RSS feed        Report issue    License
 *
 *   © 2026 GyanDev · Built with Astro on Cloudflare Pages
 *                                          CC BY-SA 4.0 (prose) · MIT (code)
 *
 * Mounted by `PageShell` (home, all-courses, course-overview, about, privacy,
 * terms, 404) and `ChapterShell` (chapter tabs). Deliberately NOT mounted in
 * `BaseLayout` so the layout file stays minimal per PHASE-1-ROADMAP §7.
 *
 * Data: reads `site/about` for author socials; missing socials silently drop.
 * Build-time only, no hydration.
 */

import { getEntry } from 'astro:content';

const about = await getEntry('site', 'about');

const socials = about?.data.author.socials ?? {};
const githubUrl = socials.github ?? 'https://github.com/sonushahuji4';

// `/contributing` + `/changelog` + `/tracks` + `/review` + `/bookmarks` are
// Phase-2 pages. Linking now so the footer doesn't need churn commits once
// they ship.
const CONTENT_LINKS: { href: string; label: string }[] = [
  { href: '/courses',   label: 'All Courses' },
  { href: '/tracks',    label: 'Tracks' },
  { href: '/review',    label: 'Review' },
  { href: '/rss.xml',   label: 'RSS Feed' },
];

const PROJECT_LINKS: { href: string; label: string; external?: boolean }[] = [
  { href: '/contributing', label: 'Contribute' },
  { href: githubUrl,       label: 'GitHub',       external: true },
  { href: '/changelog',    label: 'Changelog' },
  { href: 'https://github.com/sonushahuji4/gyandev/issues', label: 'Report Issue', external: true },
];

const LEGAL_LINKS: { href: string; label: string; external?: boolean }[] = [
  { href: '/about',   label: 'About' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms',   label: 'Terms' },
  { href: 'https://creativecommons.org/licenses/by-sa/4.0/', label: 'License', external: true },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" aria-label="Site footer">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <section class="site-footer__col site-footer__col--brand" aria-labelledby="footer-brand-heading">
        <h2 id="footer-brand-heading" class="site-footer__wordmark">
          <span class="site-footer__wordmark-text">GyanDev</span><span class="site-footer__wordmark-dot">.</span>
        </h2>
        <p class="site-footer__tagline">
          Clear, deeply-researched notes for modern engineers. Free and open-source,
          licensed under CC BY-SA 4.0.
        </p>
      </section>

      <nav class="site-footer__col" aria-labelledby="footer-content-heading">
        <h3 id="footer-content-heading" class="site-footer__heading">Content</h3>
        <ul class="site-footer__links">
          {CONTENT_LINKS.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-labelledby="footer-project-heading">
        <h3 id="footer-project-heading" class="site-footer__heading">Project</h3>
        <ul class="site-footer__links">
          {PROJECT_LINKS.map((link) => (
            <li>
              {link.external ? (
                <a href={link.href} rel="noopener noreferrer" target="_blank">{link.label}</a>
              ) : (
                <a href={link.href}>{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-labelledby="footer-legal-heading">
        <h3 id="footer-legal-heading" class="site-footer__heading">Legal</h3>
        <ul class="site-footer__links">
          {LEGAL_LINKS.map((link) => (
            <li>
              {link.external ? (
                <a href={link.href} rel="noopener noreferrer" target="_blank">{link.label}</a>
              ) : (
                <a href={link.href}>{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        © {currentYear} GyanDev · Built with Astro on Cloudflare Pages
      </p>
      <p class="site-footer__license">
        CC BY-SA 4.0 (prose) · MIT (code)
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: transparent;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    margin-top: 4rem;
  }

  .site-footer__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 2rem;
  }
  @media (min-width: 40rem) { .site-footer__inner { padding: 2.5rem 1.25rem 2rem; } }
  @media (min-width: 48rem) { .site-footer__inner { padding: 3rem 1.5rem 2.25rem; } }
  @media (min-width: 64rem) { .site-footer__inner { padding: 3.5rem 2rem 2.5rem; } }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 48rem) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem 3rem;
    }
    .site-footer__col--brand { grid-column: 1 / -1; }
  }
  @media (min-width: 64rem) {
    .site-footer__grid {
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 3rem;
    }
    .site-footer__col--brand { grid-column: auto; }
  }

  .site-footer__col { min-width: 0; }

  /* ---------- Brand column ---------- */
  .site-footer__wordmark {
    margin: 0 0 0.75rem;
    font-family: var(--font-serif), Georgia, serif;
    font-weight: 400;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .site-footer__wordmark-dot {
    color: var(--color-accent);
  }

  .site-footer__tagline {
    margin: 0;
    max-width: 22rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  /* ---------- Link columns ---------- */
  .site-footer__heading {
    margin: 0 0 0.875rem;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
  }
  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-footer__links a {
    display: inline-block;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.8125rem;
    line-height: 1.4;
  }
  .site-footer__links a:hover,
  .site-footer__links a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  /* ---------- Bottom bar ---------- */
  .site-footer__bottom {
    margin-top: 2.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  @media (min-width: 48rem) {
    .site-footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
  }

  .site-footer__copyright,
  .site-footer__license {
    margin: 0;
    line-height: 1.5;
  }

  @media print {
    .site-footer { display: none; }
  }
</style>
