---
/**
 * Mobile bottom sheet — slide-up panel used for the chapter TOC at < xl.
 *
 * Same native-`<dialog>` pattern as Drawer.astro but enters from the bottom
 * and caps at 60dvh. Dismissal: X button, backdrop click, Esc (native).
 */

interface Props {
  id: string;
  ariaLabel: string;
}

const { id, ariaLabel } = Astro.props;
---

<dialog
  id={id}
  class="bottom-sheet"
  aria-label={ariaLabel}
  data-bottom-sheet
>
  <div class="bottom-sheet__inner">
    <div class="bottom-sheet__handle" aria-hidden="true"></div>
    <div class="bottom-sheet__header">
      <button
        type="button"
        class="bottom-sheet__close"
        data-bottom-sheet-close
        aria-label="Close"
      >
        ✕
      </button>
    </div>
    <div class="bottom-sheet__content">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .bottom-sheet {
    position: fixed;
    inset: auto 0 0 0;
    margin: 0;
    width: 100vw;
    max-width: 100vw;
    max-height: 60dvh;
    padding: 0;
    background: var(--color-surface);
    color: var(--color-text);
    border: 0;
    border-top: 1px solid var(--color-border);
    border-radius: 12px 12px 0 0;
    transform: translateY(100%);
    transition: transform 200ms ease-out;
  }
  .bottom-sheet[open] {
    transform: translateY(0);
  }
  .bottom-sheet::backdrop {
    background: var(--color-backdrop);
  }
  .bottom-sheet__inner {
    display: flex;
    flex-direction: column;
    max-height: 60dvh;
  }
  .bottom-sheet__handle {
    width: 40px;
    height: 4px;
    margin: 0.5rem auto 0;
    background: var(--color-border-strong);
    border-radius: 2px;
  }
  .bottom-sheet__header {
    display: flex;
    justify-content: flex-end;
    padding: 0.25rem 0.75rem;
  }
  .bottom-sheet__close {
    min-width: 2.75rem;
    min-height: 2.75rem;
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    font-size: 1rem;
  }
  .bottom-sheet__close:hover { background: var(--color-surface-muted); }
  .bottom-sheet__content {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 1rem 1.25rem;
  }
</style>

<script>
  function bind(root: Document | HTMLElement): void {
    for (const dialog of root.querySelectorAll<HTMLDialogElement>('dialog[data-bottom-sheet]')) {
      if (dialog.dataset.sheetBound === 'true') continue;
      dialog.dataset.sheetBound = 'true';

      for (const btn of dialog.querySelectorAll<HTMLButtonElement>('[data-bottom-sheet-close]')) {
        btn.addEventListener('click', () => dialog.close());
      }

      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) dialog.close();
      });
    }
  }

  bind(document);
  document.addEventListener('astro:page-load', () => bind(document));
</script>
